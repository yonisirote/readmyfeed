  <string name="telegram_connect_title">Connect Telegram</string>
  <string name="telegram_connect_subtitle">Start the native Telegram login flow through TDLib. Your credentials stay in Telegram\'s auth flow and the session stays on-device.</string>
  <string name="telegram_status_idle_title">Ready to start Telegram login</string>
  <string name="telegram_status_idle_body">Tap a method below to begin authentication. Phone number login is the default path, and QR login is available whenever TDLib allows it.</string>
  <string name="telegram_status_initializing_title">Initializing Telegram</string>
  <string name="telegram_status_initializing_body">Starting TDLib and preparing secure on-device storage for your Telegram session.</string>
  <string name="telegram_status_phone_title">Enter your phone number</string>
  <string name="telegram_status_phone_body">Use your full phone number in international format so Telegram can send an authentication step.</string>
  <string name="telegram_status_email_title">Confirm your email address</string>
  <string name="telegram_status_email_body">Telegram requested an email address for this login. Enter the address tied to your account.</string>
  <string name="telegram_status_email_code_title">Enter the email code</string>
  <string name="telegram_status_email_code_body">Check the address Telegram masked below, then enter the email verification code it sent.</string>
  <string name="telegram_status_code_title">Enter the login code</string>
  <string name="telegram_status_code_body">Telegram sent a login code. Use the delivery details below to know where to look.</string>
  <string name="telegram_status_password_title">Enter your 2-step password</string>
  <string name="telegram_status_password_body">Your account has Telegram 2-step verification enabled. Enter the password to finish login.</string>
  <string name="telegram_status_qr_title">Scan with another Telegram device</string>
  <string name="telegram_status_qr_body">Open Telegram on a logged-in device and confirm the QR-based login using the link below.</string>
  <string name="telegram_status_ready_title">Telegram connected</string>
  <string name="telegram_status_ready_body">TDLib authentication is ready. The app can now load your main Telegram chat list on-device.</string>
  <string name="telegram_status_blocked_title">Telegram needs a follow-up step</string>
  <string name="telegram_status_blocked_body">This account hit an auth state that the UI does not support yet, such as premium purchase or registration. Restart auth or use another login path.</string>
  <string name="telegram_status_closed_title">Telegram client closed</string>
  <string name="telegram_status_closed_body">The TDLib client is closed right now. Restart the login flow to open a new Telegram session.</string>
